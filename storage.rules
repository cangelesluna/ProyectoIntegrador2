rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.role == 'ADMIN' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }

    function ownsBusiness(businessId) {
      return signedIn() &&
        firestore.get(/databases/(default)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    match /businesses/{businessId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() || ownsBusiness(businessId);
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
